{
  "compilerOptions": {
    "outDir": "./ai/dist",
    "sourceMap": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "react",
    "declaration": false,
    "rootDir": "."
  },
  "include": [
    "./ai/mcp-server.ts",
    "./ai/renderHOCToSVG.tsx",
    "./ai/componentRegistry.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ],
  "exclude": [
    "./src/docs/**/*",
    "./src/**/*.test.*"
  ]
}
