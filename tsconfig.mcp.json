{
  "compilerOptions": {
    "outDir": "./ai/dist",
    "sourceMap": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "declaration": false,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "semiotic/ai": ["./dist/semiotic-ai.d.ts"],
      "semiotic/geo": ["./dist/semiotic-geo.d.ts"]
    }
  },
  "include": [
    "./ai/mcp-server.ts",
    "./ai/renderHOCToSVG.tsx",
    "./ai/componentRegistry.ts",
    "./src/components/server/renderEvidence.ts"
  ]
}
