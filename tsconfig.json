{
  "compilerOptions": {
    "outDir": "./lib/",
    "rootDir": "./src",
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"],
    "strict": true
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx", "./src/**/*"],
  "exclude": ["./src/docs/**/*", "./src/**/*.test.*", "*.png"]
}
